{
  "name": "react-vite-tailwind",
  "private": true,
  "version": "0.4.28",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build && node scripts/fix-file-protocol.mjs && npm run build:engine",
    "preview": "vite preview",
    "play": "vite build && node scripts/fix-file-protocol.mjs && node scripts/open.mjs",
    "server": "node server/relay.mjs",
    "start": "node server/prod.mjs",
    "build:engine": "esbuild src/game/engine.ts --bundle --format=esm --platform=node --outfile=server/engine.bundle.mjs",
    "editor": "node scripts/editor-server.mjs",
    "extract:guns": "node scripts/extract-guns.mjs",
    "server:auth": "node server/authoritative.mjs",
    "smoke:server": "node scripts/smoke-server.mjs",
    "smoke:ws": "node scripts/smoke-ws.mjs"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "clsx": "2.1.1",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "tailwind-merge": "3.4.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "4.1.17",
    "@types/node": "22.19.17",
    "@types/react": "19.2.7",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "5.1.1",
    "playwright": "^1.61.1",
    "tailwindcss": "4.1.17",
    "typescript": "5.9.3",
    "vite": "7.3.2",
    "vite-plugin-singlefile": "2.3.0"
  }
}
